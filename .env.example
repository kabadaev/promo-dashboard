# ============================================================
# КОПИРАЙ ТОЗИ ФАЙЛ КАТО .env.local И ПОПЪЛНИ СТОЙНОСТИТЕ
# ============================================================

# ID на Google Sheets файла - взема се от URL-а
# https://docs.google.com/spreadsheets/d/ТУК_Е_ID-ТО/edit
SHEET_ID=1zO1zL1HIGx2m4HaInE0AM2Z9vN4ayRhV

# Email от Google Service Account (виж SETUP.md)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key от Google Service Account (viж SETUP.md)
# ВАЖНО: запази \n като буквалните два символа в стринга
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# Парола за достъп до dashboard-а (сложи каквото искаш)
DASHBOARD_PASSWORD=смени-тази-парола

# Дълъг случаен стринг за подписване на cookies (32+ символа)
# Генерирай с: openssl rand -base64 32
SESSION_SECRET=смени-с-случаен-стринг-поне-32-символа-дълъг-да
